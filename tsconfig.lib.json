{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "dist-lib",
    "rootDir": "./src",
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": [
    "src/css.d.ts",
    "src/index.ts",
    "src/components/ai-bot/**/*.ts",
    "src/components/ai-bot/**/*.tsx"
  ],
  "exclude": [
    "src/App.tsx",
    "src/main.tsx"
  ]
}
